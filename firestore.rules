rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsProfile(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == 'dharshanvva16@gmail.com';
    }

    match /userProfiles/{userId} {
      allow read, create, update: if ownsProfile(userId);
      allow delete: if ownsProfile(userId) || isAdmin();
    }

    match /albums/{albumId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /songs/{songId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
